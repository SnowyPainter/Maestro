POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maestro
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

EMBED_PROVIDER_URL=http://localhost:8080/embed
EMBED_DIM=768
EMBED_NORMALIZE=true

TEST_DOMAIN=https://unallusive-semirurally-etta.ngrok-free.app
