{
  "scripts": {
    "dev:infra": "docker compose -f infra/docker-compose.yml up -d",
    "stop:infra": "docker compose -f infra/docker-compose.yml down",
    "destroy:infra": "docker compose -f infra/docker-compose.yml down -v",

    "redis:start": "docker compose -f infra/docker-compose.redis.yml up -d",
    "redis:stop": "docker compose -f infra/docker-compose.redis.yml down -v",
    "redis:restart": "pnpm redis:stop && pnpm redis:start",

    "dev:backend": "uvicorn apps.backend.src.main:app --reload --host 0.0.0.0 --port 8000 --timeout-keep-alive 1",
    "dev:frontend": "pnpm --filter ./apps/frontend dev:with-api",
    "dev:backend:and:frontend": "concurrently -n API,FE \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:stop": "bash ./scripts/dev-stop.sh || true",
    
    "dev:celery:worker": "mkdir -p .prometheus-multiproc && PROMETHEUS_MULTIPROC_DIR=.prometheus-multiproc celery -A apps.backend.src.core.celery_app:celery_app worker -l info -Q default,sniffer,synchro,adapter,coworker,graph_rag --concurrency=4",
    "dev:celery:beat": "celery -A apps.backend.src.core.celery_app:celery_app beat -l info",
    "dev:celery": "concurrently -n WRK,BEAT \"pnpm dev:celery:worker\" \"pnpm dev:celery:beat\"",
    
    "celery:stop": "pkill -f \"celery.*apps\\.backend\\.src\\.core\\.celery_app:celery_app\" || true; pnpm redis:stop",
    "celery:start": "pnpm redis:restart && pnpm dev:celery",
    "celery:restart": "pnpm celery:stop && pnpm celery:start",

    "db:migrate": "cd apps/backend && alembic upgrade head",
    "db:migrate:generate": "cd apps/backend && alembic revision --autogenerate -m 'Update models'",
    "db:migrate:status": "cd apps/backend && alembic current",
    "db:migrate:history": "cd apps/backend && alembic history",

    "dev:all": "pnpm dev:infra && concurrently --no-auto-exit -n APP,CELERY \"pnpm dev:backend:and:frontend\" \"pnpm celery:start\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
